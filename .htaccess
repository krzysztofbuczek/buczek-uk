AddDefaultCharset UTF-8
DirectoryIndex index.html
AddType image/svg+xml .svg

<IfModule mod_rewrite.c>
  RewriteEngine On

  RewriteRule ^favicon\.ico$ https://buczek.uk/favicon.svg [R=301,L]
  RewriteRule ^industrial-sketch\.webp$ https://buczek.uk/img/industrial-sketch.webp [R=301,L]

  RewriteCond %{HTTPS} !=on [OR]
  RewriteCond %{HTTP_HOST} ^www\.buczek\.uk$ [NC]
  RewriteRule ^ https://buczek.uk%{REQUEST_URI} [R=301,L]
</IfModule>
