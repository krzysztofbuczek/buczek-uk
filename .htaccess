AddDefaultCharset UTF-8
DirectoryIndex index.html
AddType image/svg+xml .svg
AddType image/x-icon .ico
AddType application/manifest+json .webmanifest

<IfModule mod_rewrite.c>
  RewriteEngine On

  RewriteRule ^powerbi/calendar-heatmap-pro/privacy/?$ /powerbi/calendar-heatmap-pro/privacy.html [L]
  RewriteRule ^powerbi/calendar-heatmap-pro/support/?$ /powerbi/calendar-heatmap-pro/support.html [L]
  RewriteRule ^industrial-sketch\.webp$ https://buczek.uk/img/industrial-sketch.webp [R=301,L]

  RewriteCond %{HTTPS} !=on [OR]
  RewriteCond %{HTTP_HOST} ^www\.buczek\.uk$ [NC]
  RewriteRule ^ https://buczek.uk%{REQUEST_URI} [R=301,L]
</IfModule>
